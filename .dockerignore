# Used when building backend/ai's image from the repo root context
# (docker build -f backend/ai/Dockerfile .) - frontend has its own
# frontend/.dockerignore for its own build context.

**/node_modules
.git
.claude
presentation
infrastructure
frontend
.env

# backend/ai runtime-written data - never bake into the image
backend/ai/.chroma-data
backend/ai/data/employees
backend/ai/data/uploads

# backend/generator/output: employees.json/knowledgeCards.json are required
# at runtime by backend/ai/ingestion (re-ingestion is a real, recurring
# operation), and projects.json is required by backend/ai/skillGap (Active/
# Pipeline project technology demand) - only the SQL seed files and the
# JSON source nothing reads (resumes/managerReviews) are excluded.
backend/generator/output/seed.sql
backend/generator/output/employees.sql
backend/generator/output/projects.sql
backend/generator/output/resumes.json
backend/generator/output/managerReviews.json
